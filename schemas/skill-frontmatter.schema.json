{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VitaClaw SKILL Frontmatter",
  "type": "object",
  "required": [
    "name",
    "description",
    "version",
    "user-invocable",
    "allowed-tools",
    "metadata"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([-.][A-Za-z0-9]+)*$"
    },
    "user-invocable": {
      "type": "boolean"
    },
    "argument-hint": {
      "type": "string"
    },
    "allowed-tools": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "openclaw"
      ],
      "properties": {
        "openclaw": {
          "type": "object",
          "required": [
            "category"
          ],
          "properties": {
            "emoji": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "minLength": 1
            },
            "requires": {
              "type": "object",
              "properties": {
                "anyBins": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
