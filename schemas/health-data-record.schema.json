{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VitaClaw Health Data Record",
  "type": "object",
  "required": [
    "id",
    "type",
    "timestamp",
    "skill",
    "note",
    "data"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "skill": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "note": {
      "type": "string"
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
